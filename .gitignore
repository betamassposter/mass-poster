# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# …but track .env.example so contributors see required vars
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Mass Poster: generated assets (test reels, voice samples, mock clips)
/tmp/

# Skills installed locally by `npx skills add` — agent-side only, not part of product
/.agents/
skills-lock.json

# Supabase CLI local artifacts
/supabase/.temp/
/supabase/.branches/

